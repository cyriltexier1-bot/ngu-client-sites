<!-- CONTACT FORM -->
<section class="form-section" id="contact">
  <div class="wrap">
    <div class="form-wrap">
      <div class="form-intro fade-in">
        <p class="eyebrow" style="text-align:center;">Nous Contacter</p>
        <h2 class="sh" style="text-align:center;">Discutons de <span class="gold">Votre Projet</span></h2>
        <p class="body-p" style="text-align:center; margin-top:16px;">Remplissez le formulaire ci-dessous et Cyril Texier vous répondra dans les 24 heures.</p>
      </div>
      <form class="fade-in d1" action="https://formsubmit.co/teamcyril@ngurealestate.com.au" method="POST">
        <input type="hidden" name="_subject" value="Nouméa Résidences — Nouvelle Demande de Contact" />
        <input type="hidden" name="_next" value="https://cyriltexier1-bot.github.io/ngu-client-sites/azure-vue/merci.html" />
        <input type="hidden" name="_captcha" value="false" />
        <div class="form-grid">
          <div class="form-group">
            <label>Prénom</label>
            <input type="text" name="prenom" required placeholder="Jean" />
          </div>
          <div class="form-group">
            <label>Nom</label>
            <input type="text" name="nom" required placeholder="Leroux" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" required placeholder="j.leroux@email.com" />
          </div>
          <div class="form-group">
            <label>Téléphone</label>
            <input type="tel" name="telephone" placeholder="+687 ..." />
          </div>
          <div class="form-group form-full">
            <label>Sujet</label>
            <select name="sujet">
              <option value="Faisabilité du projet">Faisabilité du projet</option>
              <option value="Acquisition du terrain">Acquisition du terrain</option>
              <option value="Partenariat investissement">Partenariat investissement</option>
              <option value="Commercialisation">Commercialisation des appartements</option>
              <option value="Autre">Autre</option>
            </select>
          </div>
          <div class="form-group form-full">
            <label>Message</label>
            <textarea name="message" placeholder="Décrivez votre demande ou vos questions concernant le projet Nouméa Résidences..."></textarea>
          </div>
        </div>
        <button type="submit" class="form-submit">Envoyer le Message</button>
        <p class="form-note">Votre message sera transmis directement à Cyril Texier · NGU Real Estate. Réponse sous 24h.</p>
      </form>
    </div>
  </div>
</section>

<!-- CTA -->
<div class="cta-section">
  <div class="cta-bg"></div>
  <div class="cta-content">
    <p class="eyebrow">Prochaines Étapes</p>
